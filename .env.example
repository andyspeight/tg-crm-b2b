# Luna Desk - TG B2B CRM - environment variables
# Copy to .env.local for local dev. Set the same keys in Vercel (Production + Preview).
# Everything here is server-side only. Nothing is exposed to the browser.

# --- Auth: Stage 1 password gate (temporary stand-in until Travelgenix Control SSO) ---
# The shared password the team types to unlock the app. Use a strong value.
APP_PASSWORD=
# Random secret used to sign the session cookie. Generate with:  openssl rand -hex 32
AUTH_SECRET=

# --- Airtable (server-side only; the key must never reach the client) ---
# Personal Access Token scoped to the "TG B2B CRM" base with
# data.records:read and data.records:write. Create at https://airtable.com/create/tokens
AIRTABLE_API_KEY=
# Base id for "TG B2B CRM". Defaults to the created base in code if left unset.
AIRTABLE_BASE_ID=appPivSWEnuM2lAhi

# --- AI (Stage 3): server-side Anthropic calls for the AI Account Brief etc. ---
ANTHROPIC_API_KEY=

# --- Intel (Stage 3): Bright Data Web Scraper API (LinkedIn import + enrichment) ---
BRIGHTDATA_API_KEY=
# Optional dataset-id overrides (defaults are Bright Data's standard LinkedIn scrapers):
# BRIGHTDATA_LINKEDIN_PROFILE_DATASET=
# BRIGHTDATA_LINKEDIN_COMPANY_DATASET=
